<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Crypto Tracker</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    /* Fix accidental cursor in UI */
/* GLOBAL FIX */
*:not(input):not(textarea) {
  caret-color: transparent;
}

/* INPUT FIX */
input, textarea {
  caret-color: auto;
}
    :root {
      --bg: #0b0e11;
      --card: #161a1e;
      --border: #2b3139;
      --text: #eaecef;
      --muted: #848e9c;
      --green: #0ecb81;
      --red: #f6465d;
      --yellow: #fcd535;
    }

    body {
      background: var(--bg);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial;
      color: var(--text);
    }

    .container {
      max-width: 1200px;
    }

    h1 {
      font-weight: 700;
      letter-spacing: -0.5px;
    }

    .subtext {
      color: var(--muted);
      font-size: 14px;
    }

    .header-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 18px;
    }

    .btn-refresh {
      background: var(--yellow);
      border: none;
      color: #000;
      font-weight: 600;
      padding: 8px 14px;
      border-radius: 10px;
    }

    .btn-refresh:hover {
      opacity: 0.9;
    }

    .card-box {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 20px;
      box-shadow: 0 0 20px rgba(0,0,0,0.3);
    }

    thead th {
      color: var(--muted);
      font-weight: 500;
      font-size: 13px;
      text-transform: uppercase;
      border-bottom: 1px solid var(--border) !important;
    }

    tbody tr {
      transition: background 0.2s ease;
    }

    tbody tr:hover {
      background: #1e2329;
    }

    td {
      border-bottom: 1px solid var(--border) !important;
      vertical-align: middle;
      padding: 14px 8px;
    }

    .coin {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .coin img {
      width: 32px;
      height: 32px;
    }

    .coin-name {
      font-weight: 600;
    }

    .coin-symbol {
      font-size: 12px;
      color: var(--muted);
      text-transform: uppercase;
    }

    .price {
      font-weight: 600;
    }

  </style>
</head>

<body>

<div class="container my-5">

  <!-- HEADER -->
  <div class="header-bar">
    <div>
      <h1>Crypto Market</h1>
      <div class="subtext">Live dark-mode Coinbase-style dashboard</div>
    </div>

    <button class="btn-refresh">Refresh</button>
  </div>

  <!-- TABLE -->
  <div class="card-box">

    <table class="table table-dark table-borderless align-middle">
      <thead>
        <tr>
          <th>Asset</th>
          <th>USD Price</th>
          <th>INR Price</th>
          <th>24h Change</th>
        </tr>
      </thead>

      <tbody>
        <% coins.forEach(coin => { 
            const change = Number(coin.price_change_percentage_24h);
            const usd = Number(coin.current_price);
            const inr = usd * 83;
        %>

          <tr>

            <!-- COIN INFO -->
            <td>
              <div class="coin">
                <img src="<%=coin.image%>" alt="<%=coin.name%>">
                <div>
                  <div class="coin-name"><%=coin.name%></div>
                  <div class="coin-symbol"><%=coin.symbol%></div>
                </div>
              </div>
            </td>

            <!-- USD -->
            <td class="price">
              $<%= usd.toLocaleString() %>
            </td>

            <!-- INR -->
            <td class="price">
              ₹<%= inr.toLocaleString('en-IN') %>
            </td>

            
            <td
              style="
                color: <%= change >= 0 ? '#0ecb81' : '#f6465d' %>;
                font-weight: 700;
              "
            >
              <%= change >= 0 ? '▲' : '▼' %>
              <%= change.toFixed(2) %>%
            </td>

          </tr>

        <% }) %>
      </tbody>

    </table>

  </div>

</div>

</body>
</html>
